<!DOCTYPE html>
<html lang="en">
<head>
  <script>
    (() => {
      try {
        const s = localStorage.getItem("themeMode");
        if (s ? s === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) {
          document.documentElement.classList.add("dark");
        }
      } catch (_) {}
      document.addEventListener("basecoat:theme", (event) => {
        const mode = event.detail?.mode;
        const dark = mode === "dark" ? true : mode === "light" ? false : !document.documentElement.classList.contains("dark");
        document.documentElement.classList.toggle("dark", dark);
        try { localStorage.setItem("themeMode", dark ? "dark" : "light"); } catch (_) {}
      });
    })();
  </script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> - FacultyWare</title>
  <link rel="stylesheet" href="/assets/styles.css" />
</head>
<body>
  <aside id="sidebar" class="sidebar" data-side="left" aria-hidden="false">
    <nav aria-label="Sidebar navigation">
      <header>
        <a href="/home" class="btn-ghost p-2 h-12 w-full justify-start">
          <div class="bg-sidebar-primary text-sidebar-primary-foreground flex aspect-square size-8 items-center justify-center rounded-lg">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" class="h-4 w-4"><rect width="256" height="256" fill="none"></rect><line x1="208" y1="128" x2="128" y2="208" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="32"></line><line x1="192" y1="40" x2="40" y2="192" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="32"></line></svg>
          </div>
          <div class="grid flex-1 text-left text-sm leading-tight"><span class="truncate font-medium">FacultyWare</span><span class="truncate text-xs">Sistem Informasi</span></div>
        </a>
      </header>

      <section class="scrollbar">
        <div role="group" aria-labelledby="group-perjalanan">
          <h3 id="group-perjalanan">Perjalanan Dinas</h3>
          <ul>
            <li>
              <a href="/reimburse" class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect width="20" height="14" x="2" y="5" rx="2"/>
                  <line x1="2" x2="22" y1="10" y2="10"/>
                </svg>
                <span>Reimburse</span>
              </a>
            </li>
            <li>
              <a href="/laporan" class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
                <span>Laporan Perjalanan</span>
              </a>
            </li>
          </ul>
        </div>
      </section>

      <footer>
        <a href="/logout" class="btn-ghost p-2 h-12 w-full justify-start">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
            <polyline points="16 17 21 12 16 7"/>
            <line x1="21" x2="9" y1="12" y2="12"/>
          </svg>
          <span>Logout</span>
        </a>
      </footer>
    </nav>
  </aside>

  <main id="content">
    <header class="bg-background sticky inset-x-0 top-0 isolate flex shrink-0 items-center gap-2 border-b z-10">
      <div class="flex h-14 w-full items-center gap-2 px-4">
        <button type="button" onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))" aria-label="Toggle sidebar" class="btn-sm-icon-ghost mr-2 size-7 -ml-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="18" height="18" x="3" y="3" rx="2"/>
            <path d="M9 3v18"/>
          </svg>
        </button>
        <span class="font-semibold text-sm">Import Laporan</span>
        <div class="ml-auto flex items-center gap-2">
          <span class="text-sm text-muted-foreground">Halo, <%= locals.username || 'Pegawai' %></span>
          <a href="/logout" class="btn-sm-outline">Logout</a>
        </div>
      </div>
    </header>

    <div class="p-4 md:p-6 max-w-2xl">
      <nav class="flex items-center gap-2 text-sm text-muted-foreground mb-6">
        <a href="/laporan" class="hover:text-foreground">Laporan</a>
        <span>/</span>
        <span class="text-foreground">Import Excel</span>
      </nav>

      <!-- ALERT MESSAGE -->
      <% if (error) { %>
        <div class="alert-destructive mb-4" style="background-color: #fde8e8; color: #9b1c1c; padding: 1rem; border-radius: 0.375rem;"><p><%- error %></p></div>
      <% } %>
      <% if (success) { %>
        <div class="alert mb-4" style="background-color: #def7ec; color: #03543f; padding: 1rem; border-radius: 0.375rem;"><p><%= success %></p></div>
      <% } %>

      <div class="card">
        <header>
          <h1 class="text-xl font-bold">Import Laporan via Excel</h1>
          <p class="text-muted-foreground text-sm">Unggah berkas spreadsheet (.xlsx) untuk memasukkan beberapa data laporan sekaligus.</p>
        </header>

        <section class="mt-4">
          <div style="background-color: #e1effe; color: #1e429f; padding: 0.75rem; border-radius: 0.375rem; margin-bottom: 1rem; font-size: 0.875rem;">
            <strong>Aturan Kolom Excel:</strong><br>
            1. Baris 1 : Header Kolom<br>
            2. Kolom 1 (A): No. Surat (Request Number)<br>
            3. Kolom 2 (B): Tanggal Laporan (Format: YYYY-MM-DD)<br>
            4. Kolom 3 (C): Isi Ringkasan Laporan
          </div>

          <form class="form grid gap-4" action="/laporan/import" method="POST" enctype="multipart/form-data">
            
            <div class="grid gap-2">
              <label for="import_file">Pilih File (.xlsx) <span class="text-destructive">*</span></label>
              <input type="file" name="import_file" id="import_file" accept=".xlsx" class="input w-full" required />
              <p class="text-xs text-muted-foreground">Pastikan ekstensi file adalah .xlsx dengan ukuran maksimal 5MB.</p>
            </div>

            <div class="flex gap-2 mt-2">
              <a href="/laporan" class="btn-outline">Batal</a>
              <button type="submit" class="btn">Import</button>
            </div>
          </form>
        </section>
      </div>
    </div>
  </main>

  <script src="/assets/js/basecoat.js" defer></script>
  <script src="/assets/js/sidebar.js" defer></script>
</body>
</html>