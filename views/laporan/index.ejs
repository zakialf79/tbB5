<!doctype html>
<html lang="en">
<head>
  <script>(() => { try { const s = localStorage.getItem("themeMode"); if (s ? s==="dark" : matchMedia("(prefers-color-scheme: dark)").matches) document.documentElement.classList.add("dark"); } catch(_){} document.addEventListener("basecoat:theme",(e)=>{ const m=e.detail?.mode; const d=m==="dark"?true:m==="light"?false:!document.documentElement.classList.contains("dark"); document.documentElement.classList.toggle("dark",d); try{localStorage.setItem("themeMode",d?"dark":"light");}catch(_){} }); })();</script>
  <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> - FacultyWare</title>
  <link rel="stylesheet" href="/assets/styles.css" />
</head>
<body>
  <aside id="sidebar" class="sidebar" data-side="left" aria-hidden="false">
    <nav aria-label="Sidebar navigation">
      <header>
        <a href="/home" class="btn-ghost p-2 h-12 w-full justify-start">
          <div class="bg-sidebar-primary text-sidebar-primary-foreground flex aspect-square size-8 items-center justify-center rounded-lg">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" class="h-4 w-4"><rect width="256" height="256" fill="none"></rect><line x1="208" y1="128" x2="128" y2="208" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="32"></line><line x1="192" y1="40" x2="40" y2="192" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="32"></line></svg>
          </div>
          <div class="grid flex-1 text-left text-sm leading-tight"><span class="truncate font-medium">FacultyWare</span><span class="truncate text-xs">Sistem Informasi</span></div>
        </a>
      </header>
      <section class="scrollbar">
        <div role="group" aria-labelledby="group-perjalanan"><h3 id="group-perjalanan">Perjalanan Dinas</h3>
          <ul>
            <li><a href="/reimburse"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg><span>Reimburse</span></a></li>
            <li><a href="/laporan"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg><span>Laporan Perjalanan</span></a></li>
          </ul>
        </div>
      </section>
      <footer><a href="/logout" class="btn-ghost p-2 h-12 w-full justify-start"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg><span>Logout</span></a></footer>
    </nav>
  </aside>

  <main id="content">
    <header class="bg-background sticky inset-x-0 top-0 isolate flex shrink-0 items-center gap-2 border-b z-10">
      <div class="flex h-14 w-full items-center gap-2 px-4">
        <button type="button" onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))" aria-label="Toggle sidebar" class="btn-sm-icon-ghost mr-2 size-7 -ml-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 3v18"/></svg>
        </button>
        <span class="font-semibold text-sm">Laporan Perjalanan Dinas</span>
        <div class="ml-auto flex items-center gap-2">
          <span class="text-sm text-muted-foreground">Halo, <%= locals.username || 'Pegawai' %></span>
          <a href="/logout" class="btn-sm-outline">Logout</a>
        </div>
      </div>
    </header>

    <div class="p-4 md:p-6">
      <div class="flex items-center justify-between mb-6">
        <div>
          <h1 class="text-2xl font-bold tracking-tight">Daftar Laporan</h1>
          <p class="text-muted-foreground text-sm mt-1">Total: <%= total %> laporan</p>
        </div>
        <a href="/laporan/create" class="btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
          Kirim Laporan
        </a>
      </div>

      <form method="GET" action="/laporan" class="flex gap-2 mb-4">
        <input type="text" name="search" value="<%= search %>" placeholder="Cari berdasarkan tujuan, nomor surat, atau isi laporan..." class="input flex-1" />
        <button type="submit" class="btn-outline">Cari</button>
        <% if (search) { %><a href="/laporan" class="btn-ghost">Reset</a><% } %>
      </form>

      <div class="card p-0 overflow-hidden">
        <table class="table w-full">
          <thead>
            <tr>
              <th>No. Surat</th>
              <th>Tujuan</th>
              <th>Tanggal Perjalanan</th>
              <th>Tanggal Laporan</th>
              <th>Lampiran</th>
              <th>Aksi</th>
            </tr>
          </thead>
          <tbody>
            <% if (laporans.length === 0) { %>
              <tr><td colspan="6" class="text-center text-muted-foreground py-8">Belum ada laporan.</td></tr>
            <% } else { %>
              <% laporans.forEach(function(l) { %>
                <tr>
                  <td class="font-mono text-sm"><%= l.request_number %></td>
                  <td><%= l.destination %></td>
                  <td class="text-sm">
                    <%= new Date(l.start_date).toLocaleDateString('id-ID', {day:'2-digit',month:'short',year:'numeric'}) %>
                    –
                    <%= new Date(l.end_date).toLocaleDateString('id-ID', {day:'2-digit',month:'short',year:'numeric'}) %>
                  </td>
                  <td><%= new Date(l.report_date).toLocaleDateString('id-ID', {day:'2-digit',month:'short',year:'numeric'}) %></td>
                  <td>
                    <% if (l.attachment) { %>
                      <a href="/uploads/laporan/<%= l.attachment %>" target="_blank" class="btn-sm-outline">Lihat</a>
                    <% } else { %>
                      <span class="text-muted-foreground text-sm">-</span>
                    <% } %>
                  </td>
                  <td>
                    <a href="/laporan/<%= l.id %>/edit" class="btn-sm">Edit</a>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>

      <% if (totalPages > 1) { %>
        <nav class="flex items-center justify-between mt-4">
          <p class="text-sm text-muted-foreground">Halaman <%= currentPage %> dari <%= totalPages %></p>
          <div class="flex gap-1">
            <% if (currentPage > 1) { %><a href="/laporan?page=<%= currentPage-1 %>&search=<%= search %>" class="btn-sm-outline">← Sebelumnya</a><% } %>
            <% for (let i = 1; i <= totalPages; i++) { %>
              <a href="/laporan?page=<%= i %>&search=<%= search %>" class="<%= i===currentPage?'btn-sm':'btn-sm-outline' %>"><%= i %></a>
            <% } %>
            <% if (currentPage < totalPages) { %><a href="/laporan?page=<%= currentPage+1 %>&search=<%= search %>" class="btn-sm-outline">Selanjutnya →</a><% } %>
          </div>
        </nav>
      <% } %>
    </div>
  </main>
  <script src="/assets/js/basecoat.js" defer></script>
  <script src="/assets/js/sidebar.js" defer></script>
</body>
</html>
