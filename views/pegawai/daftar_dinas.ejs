<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light">
  <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4 shadow-sm">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/pegawai/perjalanan-dinas">Modul Pegawai B5</a>
      <div class="navbar-nav ms-auto">
        <a class="nav-link text-white" href="/home">Home</a>
        <a class="nav-link text-white" href="/api/v1/pegawai/perjalanan-dinas" target="_blank">API JSON</a>
      </div>
    </div>
  </nav>

  <div class="container py-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2 class="fw-bold mb-1">Permohonan Perjalanan Dinas Saya</h2>
        <p class="text-muted mb-0">Fitur 1–6: tambah, lihat, ubah, hapus, ekspor/impor, dan API JSON.</p>
      </div>
      <div class="d-flex gap-2">
        <a href="/pegawai/perjalanan-dinas/tambah" class="btn btn-success"><i class="fas fa-plus me-1"></i>Tambah</a>
        <a href="/pegawai/perjalanan-dinas/ekspor" class="btn btn-outline-primary"><i class="fas fa-download me-1"></i>Ekspor</a>
        <a href="/pegawai/perjalanan-dinas/impor" class="btn btn-outline-secondary"><i class="fas fa-upload me-1"></i>Impor</a>
      </div>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white py-3">
        <h5 class="mb-0 fw-semibold text-primary">Daftar Permohonan Milik Pegawai</h5>
      </div>
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead class="table-light">
              <tr>
                <th>No. Permohonan</th>
                <th>Maksud</th>
                <th>Tujuan</th>
                <th>Tanggal</th>
                <th>Status</th>
                <th class="text-end">Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% if (dataDinas.length === 0) { %>
                <tr>
                  <td colspan="6" class="text-center text-muted py-5">Belum ada permohonan perjalanan dinas.</td>
                </tr>
              <% } else { %>
                <% dataDinas.forEach(function(dinas) { %>
                  <tr>
                    <td class="fw-bold"><%= dinas.request_number %></td>
                    <td><%= dinas.purpose %></td>
                    <td><%= dinas.destination %></td>
                    <td>
                      <%= new Date(dinas.start_date).toLocaleDateString('id-ID') %> -
                      <%= new Date(dinas.end_date).toLocaleDateString('id-ID') %>
                    </td>
                    <td>
                      <span class="badge <%= dinas.status === 'pending' ? 'bg-warning text-dark' : (dinas.status === 'approved' ? 'bg-success' : 'bg-danger') %>">
                        <%= dinas.status %>
                      </span>
                    </td>
                    <td class="text-end">
                      <% if (dinas.status === 'pending') { %>
                        <a href="/pegawai/perjalanan-dinas/edit/<%= dinas.id %>" class="btn btn-sm btn-outline-warning">Edit</a>
                        <form action="/pegawai/perjalanan-dinas/hapus/<%= dinas.id %>" method="POST" class="d-inline" onsubmit="return confirm('Hapus permohonan ini?')">
                          <button type="submit" class="btn btn-sm btn-outline-danger">Hapus</button>
                        </form>
                      <% } else { %>
                        <span class="text-muted small">Sudah diproses</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
