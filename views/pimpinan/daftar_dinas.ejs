<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Persetujuan Perjalanan Dinas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4 shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold text-info" href="/pimpinan/perjalanan-dinas">Modul Pimpinan B5</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link active" href="/pimpinan/perjalanan-dinas">
                            <i class="fas fa-list me-1"></i> Daftar Dinas (Fitur 7)
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-warning" href="/api/v1/pimpinan/perjalanan-dinas" target="_blank">
                            <i class="fas fa-code me-1"></i> Cek API JSON (Fitur 12)
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container py-3">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold text-dark">Persetujuan Perjalanan Dinas (Modul B5)</h2>
                <p class="text-muted">Halaman Khusus Pimpinan / Admin</p>
            </div>
            <a href="/pimpinan/perjalanan-dinas/ekspor" class="btn btn-primary shadow-sm">
                <i class="fas fa-download me-2"></i>Ekspor Data
            </a>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-3">
                <h5 class="card-title mb-0 fw-semibold text-primary">Daftar Permohonan Seluruh Pegawai</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>No. Permohonan</th>
                                <th>Nama Pegawai</th>
                                <th>Tujuan</th>
                                <th>Maksud Perjalanan</th>
                                <th>Tanggal Berangkat</th>
                                <th>Status</th>
                                <th>Aksi</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (dataDinas.length === 0) { %>
                                <tr>
                                    <td colspan="7" class="text-center text-muted py-5">
                                        <i class="fas fa-folder-open fa-2x mb-3 d-block text-secondary"></i>
                                        Belum ada pengajuan perjalanan dinas dari pegawai.
                                    </td>
                                </tr>
                            <% } else { %>
                                <% dataDinas.forEach(function(dinas) { %>
                                    <tr>
                                        <td class="fw-bold"><%= dinas.request_number %></td>
                                        <td><%= dinas.nama_pegawai %></td>
                                        <td><%= dinas.destination %></td>
                                        <td><%= dinas.purpose %></td>
                                        <td><%= new Date(dinas.start_date).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' }) %></td>
                                        <td>
                                            <span class="badge <%= dinas.status === 'pending' ? 'bg-warning text-dark' : (dinas.status === 'approved' ? 'bg-success' : 'bg-danger') %>">
                                                <%= dinas.status %>
                                            </span>
                                        </td>
                                        <td>
                                            <a href="/pimpinan/perjalanan-dinas/detail/<%= dinas.id %>" class="btn btn-sm btn-outline-info">Periksa</a>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>