<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Detail Permohonan Perjalanan Dinas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light">

    <div class="container py-5">
        <div class="mb-4">
            <a href="/pimpinan/perjalanan-dinas" class="btn btn-outline-secondary btn-sm">
                <i class="fas fa-arrow-left me-2"></i>Kembali ke Daftar
            </a>
        </div>

        <div class="row">
            <div class="col-md-8">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-white py-3">
                        <h5 class="card-title mb-0 fw-semibold text-primary">Detail Permohonan: <%= dinas.request_number %></h5>
                    </div>
                    <div class="card-body">
                        <table class="table table-bordered align-middle">
                            <tr>
                                <th class="table-light" width="30%">Maksud Perjalanan</th>
                                <td><%= dinas.purpose %></td>
                            </tr>
                            <tr>
                                <th class="table-light">Kota Tujuan</th>
                                <td><%= dinas.destination %></td>
                            </tr>
                            <tr>
                                <th class="table-light">Tanggal Berangkat</th>
                                <td><%= new Date(dinas.start_date).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' }) %></td>
                            </tr>
                            <tr>
                                <th class="table-light">Tanggal Kembali</th>
                                <td><%= new Date(dinas.end_date).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' }) %></td>
                            </tr>
                            <tr>
                                <th class="table-light">Status Saat Ini</th>
                                <td>
                                    <span class="badge <%= dinas.status === 'pending' ? 'bg-warning text-dark' : (dinas.status === 'approved' ? 'bg-success' : 'bg-danger') %>">
                                        <%= dinas.status %>
                                    </span>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white py-3">
                        <h5 class="card-title mb-0 fw-semibold text-dark">Form Keputusan</h5>
                    </div>
                    <div class="card-body">
                        <% if (dinas.status === 'pending') { %>
                            <form action="/pimpinan/perjalanan-dinas/aksi/<%= dinas.id %>" method="POST">
                                <div class="mb-3">
                                    <label for="catatan" class="form-label fw-medium">Catatan Pimpinan (Opsional)</label>
                                    <textarea class="form-control" id="catatan" name="catatan" rows="3" placeholder="Berikan alasan keputusan..."></textarea>
                                </div>
                                <div class="d-grid gap-2">
                                    <button type="submit" name="status" value="approved" class="btn btn-success">
                                        <i class="fas fa-check me-2"></i>Setujui Permohonan
                                    </button>
                                    <button type="submit" name="status" value="rejected" class="btn btn-danger">
                                        <i class="fas fa-times me-2"></i>Tolak Permohonan
                                    </button>
                                </div>
                            </form>
                        <% } else { %>
                            <div class="alert alert-info text-center mb-0" role="alert">
                                <i class="fas fa-info-circle me-2"></i>Permohonan ini sudah diproses dengan status <strong><%= dinas.status %></strong>.
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>