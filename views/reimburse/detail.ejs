<!doctype html>
<html lang="en">
<head>
  <script>
    (() => {
      try {
        const stored = localStorage.getItem("themeMode");
        if (stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) {
          document.documentElement.classList.add("dark");
        }
      } catch (_) {}
      document.addEventListener("basecoat:theme", (event) => {
        const mode = event.detail?.mode;
        const dark = mode === "dark" ? true : mode === "light" ? false : !document.documentElement.classList.contains("dark");
        document.documentElement.classList.toggle("dark", dark);
        try { localStorage.setItem("themeMode", dark ? "dark" : "light"); } catch (_) {}
      });
    })();
  </script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> - FacultyWare</title>
  <link rel="stylesheet" href="/assets/styles.css" />
</head>
<body>

  <!-- SIDEBAR -->
  <aside id="sidebar" class="sidebar" data-side="left" aria-hidden="false">
    <nav aria-label="Sidebar navigation">
      <header>
        <a href="/home" class="btn-ghost p-2 h-12 w-full justify-start">
          <div class="bg-sidebar-primary text-sidebar-primary-foreground flex aspect-square size-8 items-center justify-center rounded-lg">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" class="h-4 w-4">
              <rect width="256" height="256" fill="none"></rect>
              <line x1="208" y1="128" x2="128" y2="208" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="32"></line>
              <line x1="192" y1="40" x2="40" y2="192" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="32"></line>
            </svg>
          </div>
          <div class="grid flex-1 text-left text-sm leading-tight">
            <span class="truncate font-medium">FacultyWare</span>
            <span class="truncate text-xs">Sistem Informasi</span>
          </div>
        </a>
      </header>
      <section class="scrollbar">
        <div role="group" aria-labelledby="group-perjalanan">
          <h3 id="group-perjalanan">Perjalanan Dinas</h3>
          <ul>
            <li>
              <a href="/reimburse">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                  fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect width="20" height="14" x="2" y="5" rx="2"/>
                  <line x1="2" x2="22" y1="10" y2="10"/>
                </svg>
                <span>Reimburse</span>
              </a>
            </li>
            <li>
              <a href="/laporan">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                  fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
                <span>Laporan Perjalanan</span>
              </a>
            </li>
          </ul>
        </div>
      </section>
      <footer>
        <a href="/logout" class="btn-ghost p-2 h-12 w-full justify-start">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
            <polyline points="16 17 21 12 16 7"/>
            <line x1="21" x2="9" y1="12" y2="12"/>
          </svg>
          <span>Logout</span>
        </a>
      </footer>
    </nav>
  </aside>

  <!-- MAIN CONTENT -->
  <main id="content">

    <!-- TOPBAR -->
    <header class="bg-background sticky inset-x-0 top-0 isolate flex shrink-0 items-center gap-2 border-b z-10">
      <div class="flex h-14 w-full items-center gap-2 px-4">
        <button
          type="button"
          onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))"
          aria-label="Toggle sidebar"
          class="btn-sm-icon-ghost mr-2 size-7 -ml-1.5"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="18" height="18" x="3" y="3" rx="2" /><path d="M9 3v18" />
          </svg>
        </button>
        <span class="font-semibold text-sm">Detail Reimburse</span>
        <div class="ml-auto flex items-center gap-2">
          <span class="text-sm text-muted-foreground">Halo, <%= locals.username || 'Pegawai' %></span>
          <a href="/logout" class="btn-sm-outline">Logout</a>
        </div>
      </div>
    </header>

    <div class="p-4 md:p-6 max-w-2xl">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-muted-foreground mb-6">
        <a href="/reimburse" class="hover:text-foreground">Reimburse</a>
        <span>/</span>
        <span class="text-foreground">Detail</span>
      </nav>

      <!-- Card detail -->
      <div class="card">
        <header class="flex items-start justify-between">
          <div>
            <h1 class="text-xl font-bold">Detail Pengajuan Reimburse</h1>
            <p class="text-muted-foreground text-sm mt-1"><%= reimburse.komponen %> — <%= reimburse.komponen_code %></p>
          </div>
          <% if (reimburse.status === 'submitted') { %>
            <span class="badge">Diajukan</span>
          <% } else if (reimburse.status === 'approved') { %>
            <span class="badge-success">Disetujui</span>
          <% } else { %>
            <span class="badge-destructive">Ditolak</span>
          <% } %>
        </header>

        <section class="grid gap-4 mt-4">
          <!-- Info perjalanan dinas -->
          <div class="rounded-lg border p-4 grid gap-3">
            <h2 class="text-sm font-semibold text-muted-foreground uppercase tracking-wide">Info Perjalanan Dinas</h2>
            <div class="grid grid-cols-2 gap-3 text-sm">
              <div>
                <p class="text-muted-foreground">No. Surat</p>
                <p class="font-mono font-medium"><%= reimburse.request_number %></p>
              </div>
              <div>
                <p class="text-muted-foreground">Tujuan</p>
                <p class="font-medium"><%= reimburse.destination %></p>
              </div>
              <div>
                <p class="text-muted-foreground">Keperluan</p>
                <p class="font-medium"><%= reimburse.purpose %></p>
              </div>
              <div>
                <p class="text-muted-foreground">Tanggal</p>
                <p class="font-medium">
                  <%= new Date(reimburse.start_date).toLocaleDateString('id-ID', {day:'2-digit',month:'short',year:'numeric'}) %>
                  –
                  <%= new Date(reimburse.end_date).toLocaleDateString('id-ID', {day:'2-digit',month:'short',year:'numeric'}) %>
                </p>
              </div>
            </div>
          </div>

          <!-- Info reimburse -->
          <div class="rounded-lg border p-4 grid gap-3">
            <h2 class="text-sm font-semibold text-muted-foreground uppercase tracking-wide">Info Reimburse</h2>
            <div class="grid grid-cols-2 gap-3 text-sm">
              <div>
                <p class="text-muted-foreground">Komponen Biaya</p>
                <p class="font-medium"><%= reimburse.komponen %></p>
              </div>
              <div>
                <p class="text-muted-foreground">Jumlah</p>
                <p class="font-medium text-lg">Rp <%= Number(reimburse.amount).toLocaleString('id-ID') %></p>
              </div>
              <div class="col-span-2">
                <p class="text-muted-foreground">Keterangan</p>
                <p class="font-medium"><%= reimburse.description || '-' %></p>
              </div>
              <div>
                <p class="text-muted-foreground">Tanggal Ajukan</p>
                <p class="font-medium"><%= new Date(reimburse.submitted_at).toLocaleDateString('id-ID', {day:'2-digit',month:'long',year:'numeric'}) %></p>
              </div>
              <% if (reimburse.verified_at) { %>
              <div>
                <p class="text-muted-foreground">Tanggal Verifikasi</p>
                <p class="font-medium"><%= new Date(reimburse.verified_at).toLocaleDateString('id-ID', {day:'2-digit',month:'long',year:'numeric'}) %></p>
              </div>
              <% } %>
              <% if (reimburse.receipt_file) { %>
              <div class="col-span-2">
                <p class="text-muted-foreground">Bukti Pengeluaran</p>
                <a href="/uploads/<%= reimburse.receipt_file %>" target="_blank" class="btn-sm-outline mt-1 inline-flex">
                  Lihat Bukti
                </a>
              </div>
              <% } %>
            </div>
          </div>
        </section>

        <footer class="flex gap-2 mt-4">
          <a href="/reimburse" class="btn-outline">← Kembali</a>
          <% if (reimburse.status === 'submitted') { %>
            <a href="/reimburse/<%= reimburse.id %>/edit" class="btn">Edit</a>
          <% } %>
        </footer>
      </div>

    </div>
  </main>

  <script src="/assets/js/basecoat.js" defer></script>
  <script src="/assets/js/sidebar.js" defer></script>
</body>
</html>
